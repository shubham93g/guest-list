# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste raw multi-line PEM string in Vercel dashboard.
# In .env.local, use \n-escaped single line: "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# OTP delivery method: 'skip' (default), 'sms', or 'whatsapp'
# 'skip' issues a session immediately without sending or verifying a code —
# use as an operational escape hatch when OTP providers are unavailable.
OTP_CHANNEL=skip

# Twilio Verify — required when OTP_CHANNEL=sms or OTP_CHANNEL=whatsapp
# WhatsApp requires a Meta-approved WhatsApp Business Account on the Verify Service.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# JWT session signing (generate with: openssl rand -hex 32)
JWT_SECRET=

# Event configuration — edit src/config/wedding.ts directly (no env vars needed)
